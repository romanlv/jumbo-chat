# LLM — one of these is required
ANTHROPIC_API_KEY=           # Standard API key (recommended)
ANTHROPIC_AUTH_TOKEN=        # Dev only — Claude Max OAuth token (uses Claude Code session workaround)

# Embeddings — required for ingestion
OPENAI_API_KEY=

# Scraping — only needed for `bun run ingest --fetch`
FIRECRAWL_API_KEY=

# Database — optional, defaults to local file (file:local.db)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
